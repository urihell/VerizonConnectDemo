<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Fires when a RecordsetFltrCritMonitor record changes IsWithinThreshold to false (threshold breach). Creates a Task alerting the VDD Fleet Agent to diagnose and create a proactive replacement case.</description>
    <interviewLabel>VDD_Threshold_Breach_Trigger-{!$Flow.CurrentDateTime}</interviewLabel>
    <label>VDD Threshold Breach Trigger</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Breach_Alert</name>
        <label>Create Breach Alert</label>
        <locationX>176</locationX>
        <locationY>335</locationY>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <stringValue>VDD Threshold Breach - Proactive Service Required</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Description</field>
            <value>
                <elementReference>breachDescription</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Priority</field>
            <value>
                <stringValue>High</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WhatId</field>
            <value>
                <elementReference>$Record.AssetId</elementReference>
            </value>
        </inputAssignments>
        <object>Task</object>
    </recordCreates>
    <formulas>
        <name>breachDescription</name>
        <dataType>String</dataType>
        <expression>'Health threshold breach detected on monitor ' + {!$Record.Name} + '. Agentforce: Use Proactive Health Monitor topic to diagnose asset health, create replacement case, and notify customer proactively.'</expression>
    </formulas>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Breach_Alert</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>IsWithinThreshold</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>RecordsetFltrCritMonitor</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
