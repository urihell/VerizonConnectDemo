    <invocationTargetType>apex</invocationTargetType>
    <isConfirmationRequired>true</isConfirmationRequired>
    <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
    <masterLabel>Create Installer Work Order</masterLabel>
    <progressIndicatorMessage>Creating installer work order for this vehicle...</progressIndicatorMessage>
