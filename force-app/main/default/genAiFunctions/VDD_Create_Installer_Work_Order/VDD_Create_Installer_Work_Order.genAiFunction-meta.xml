<?xml version="1.0" encoding="UTF-8"?>
<GenAiFunction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Creates a Work Order and linked Service Appointment for a 3rd-party installer. Requires device details, customer info, delivery address, and the 3 preferred date/time preferences collected in the previous step. Stores preferences in custom fields on both WorkOrder and ServiceAppointment. Returns the work order number and service appointment ID.</description>
