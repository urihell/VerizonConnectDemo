<?xml version="1.0" encoding="UTF-8"?>
<GenAiFunction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Checks the current installation status of a fleet asset including whether the device has been installed, the install date, and associated customer information. Pass assetId for direct lookup or contactId to find the most recent installed asset for the customer. Use contactId when the customer contacts via SMS.</description>
    <invocationTarget>VDD_GetInstallStatus</invocationTarget>
    <invocationTargetType>apex</invocationTargetType>
    <isConfirmationRequired>false</isConfirmationRequired>
    <mappingAttributes>
        <label>Asset ID</label>
        <name>input_assetId</name>
        <parameterName>assetId</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Contact ID</label>
        <name>input_contactId</name>
        <parameterName>contactId</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Asset ID</label>
        <name>output_assetId</name>
        <parameterName>assetId</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Asset Name</label>
        <name>output_assetName</name>
        <parameterName>assetName</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Serial Number</label>
        <name>output_serialNumber</name>
        <parameterName>serialNumber</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Vehicle Name</label>
        <name>output_vehicleName</name>
        <parameterName>vehicleName</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Install Date</label>
        <name>output_installDate</name>
        <parameterName>installDate</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Customer Name</label>
        <name>output_customerName</name>
        <parameterName>customerName</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Customer Email</label>
        <name>output_customerEmail</name>
        <parameterName>customerEmail</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Customer Phone</label>
        <name>output_customerPhone</name>
        <parameterName>customerPhone</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Contact ID</label>
        <name>output_contactId</name>
        <parameterName>contactId</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Asset Status</label>
        <name>output_assetStatus</name>
        <parameterName>assetStatus</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Is Installed</label>
        <name>output_isInstalled</name>
        <parameterName>isInstalled</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Success</label>
        <name>output_success</name>
        <parameterName>success</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Message</label>
        <name>output_message</name>
        <parameterName>message</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <masterLabel>Get Install Status</masterLabel>
</GenAiFunction>
