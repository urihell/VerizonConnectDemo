<?xml version="1.0" encoding="UTF-8"?>
<GenAiFunction xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Sends an onboarding welcome message to the customer after successful device installation and telemetry confirmation. Includes device details and telemetry metrics in the communication.</description>
    <invocationTarget>VDD_SendOnboardingMessage</invocationTarget>
    <invocationTargetType>apex</invocationTargetType>
    <isConfirmationRequired>true</isConfirmationRequired>
    <mappingAttributes>
        <label>Contact ID</label>
        <name>input_contactId</name>
        <parameterName>contactId</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Asset ID</label>
        <name>input_assetId</name>
        <parameterName>assetId</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Customer Name</label>
        <name>input_customerName</name>
        <parameterName>customerName</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Serial Number</label>
        <name>input_serialNumber</name>
        <parameterName>serialNumber</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Vehicle Name</label>
        <name>input_vehicleName</name>
        <parameterName>vehicleName</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>All Metrics</label>
        <name>input_allMetrics</name>
        <parameterName>allMetrics</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Telemetry Status</label>
        <name>input_telemetryStatus</name>
        <parameterName>telemetryStatus</parameterName>
        <parameterType>input</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Task ID</label>
        <name>output_taskId</name>
        <parameterName>taskId</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Confirmation Message</label>
        <name>output_confirmationMessage</name>
        <parameterName>confirmationMessage</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <mappingAttributes>
        <label>Success</label>
        <name>output_success</name>
        <parameterName>success</parameterName>
        <parameterType>output</parameterType>
    </mappingAttributes>
    <masterLabel>Send Onboarding Message</masterLabel>
</GenAiFunction>
